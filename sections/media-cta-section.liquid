<section class="media-cta-section" id="media-cta-{{ section.id }}">
  <div class="media-cta-section__wrapper">

    <!-- Background Media -->
    {% if section.settings.media_type == 'video' and section.settings.video_url != blank %}
      <div class="media-cta-section__media">
        <video autoplay muted loop playsinline>
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        </video>
      </div>
    {% elsif section.settings.media_type == 'image' %}
      {% if section.settings.image != blank %}
        <div class="media-cta-section__media media-cta-section__media--desktop">
          <img
            src="{{ section.settings.image | image_url: width: 1920 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        </div>
      {% endif %}
      {% if section.settings.image_mobile != blank %}
        <div class="media-cta-section__media media-cta-section__media--mobile">
          <img
            src="{{ section.settings.image_mobile | image_url: width: 800 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="{{ section.settings.image_mobile.width }}"
            height="{{ section.settings.image_mobile.height }}"
          >
        </div>
      {% elsif section.settings.image != blank %}
        <div class="media-cta-section__media media-cta-section__media--mobile">
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        </div>
      {% endif %}
    {% endif %}

    <!-- Overlay -->
    <div class="media-cta-section__overlay"></div>

    <!-- Content -->
    <div class="media-cta-section__content">
      {% if section.settings.heading != blank %}
        <h2 class="media-cta-section__heading">{{ section.settings.heading | escape }}</h2>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="media-cta-section__description">{{ section.settings.description | escape }}</p>
      {% endif %}

      {% if section.settings.show_email_form %}
        <div class="media-cta-section__form-wrapper">
          {%- form 'customer', class: 'media-cta-section__form' -%}
            <div class="media-cta-section__input-group">
              <label for="MediaCtaEmail-{{ section.id }}" class="visually-hidden">Email address</label>
              <input
                id="MediaCtaEmail-{{ section.id }}"
                class="media-cta-section__input"
                type="email"
                name="contact[email]"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                placeholder="{{ section.settings.input_placeholder | default: 'your@email.com' }}"
                required
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="media-cta-error-{{ section.id }}"
                {% elsif form.posted_successfully? %}
                  aria-describedby="media-cta-success-{{ section.id }}"
                {% endif %}
              >
              <button class="media-cta-section__button" type="submit">
                {{ section.settings.button_label | default: 'Notify Me' }}
              </button>
            </div>

            {%- if form.errors -%}
              <p id="media-cta-error-{{ section.id }}" class="media-cta-section__message media-cta-section__message--error">
                {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
              </p>
            {%- endif -%}

            {%- if form.posted_successfully? -%}
              <p id="media-cta-success-{{ section.id }}" class="media-cta-section__message media-cta-section__message--success">
                Thanks for signing up!
              </p>
            {%- endif -%}
          {%- endform -%}
        </div>
      {% endif %}
    </div>

  </div>
</section>

<style>
/* ============================================
   MEDIA CTA SECTION
   ============================================ */

.media-cta-section {
  margin-top: 8px;
}

.media-cta-section__wrapper {
  position: relative;
  border-radius: 8px;
  overflow: hidden;
  min-height: 480px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #28282A;
}

/* ---- Background Media ---- */
.media-cta-section__media {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

.media-cta-section__media img,
.media-cta-section__media video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Desktop/mobile image switching */
.media-cta-section__media--mobile {
  display: none;
}

@media screen and (max-width: 749px) {
  .media-cta-section__media--desktop {
    display: none;
  }
  .media-cta-section__media--mobile {
    display: block;
  }
}

/* ---- Overlay ---- */
.media-cta-section__overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.35);
  z-index: 2;
}

/* ---- Content ---- */
.media-cta-section__content {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 1em;
  padding: 3em 2em;
  width: 100%;
  max-width: 700px;
}

/* ---- Heading ---- */
.media-cta-section__heading {
  font-family: var(--font-header) !important;
  font-weight: var(--font-weight-semibold) !important;
  text-transform: uppercase !important;
  color: #EDEAE4 !important;
  margin: 0 !important;
  line-height: 1 !important;
}

/* ---- Description ---- */
.media-cta-section__description {
  font-family: var(--font-body) !important;
  font-size: 0.8rem !important;
  text-transform: uppercase;
  color: rgba(237, 234, 228, 0.75);
  margin: 0 !important;
  line-height: 1.5;
  letter-spacing: 0.05em;
}

/* ---- Email Form ---- */
.media-cta-section__form-wrapper {
  width: 100%;
  max-width: 420px;
  margin-top: 0.5em;
}

.media-cta-section__form {
  width: 100%;
}

.media-cta-section__input-group {
  display: flex;
  gap: 0;
  width: 100%;
}

.media-cta-section__input {
  flex: 1;
  padding: 13px 16px;
  border: none;
  background-color: rgba(237, 234, 228, 0.88) !important;
  color: #171717;
  font-family: var(--font-body) !important;
  text-transform: uppercase;
  font-size: 0.8rem;
  border-radius: 0;
  outline: none;
}

.media-cta-section__input::placeholder {
  color: rgba(23, 23, 23, 0.55);
  text-transform: uppercase;
}

.media-cta-section__input:focus {
  background-color: #EDEAE4 !important;
}

.media-cta-section__button {
  padding: 13px 20px;
  background-color: #171717;
  color: #EDEAE4;
  border: none;
  font-family: var(--font-button) !important;
  text-transform: uppercase;
  font-size: 0.8rem;
  cursor: pointer;
  transition: opacity 0.3s ease;
  border-radius: 0;
  white-space: nowrap;
  letter-spacing: 0.05em;
}

.media-cta-section__button:hover {
  opacity: 0.8;
}

.media-cta-section__message {
  margin-top: 0.75em;
  font-family: var(--font-body) !important;
  font-size: 0.75rem !important;
  text-transform: uppercase;
  text-align: center;
}

.media-cta-section__message--error {
  color: #ff8a8a;
}

.media-cta-section__message--success {
  color: #69db7c;
}

/* ============================================
   RESPONSIVE — MOBILE
   ============================================ */
@media screen and (max-width: 749px) {
  .media-cta-section__wrapper {
    min-height: 400px;
  }

  .media-cta-section__content {
    padding: 2em 1.25em;
    gap: 0.875em;
  }

  .media-cta-section__form-wrapper {
    max-width: 100%;
  }

  .media-cta-section__input-group {
    flex-direction: column;
    gap: 8px;
  }

  .media-cta-section__input,
  .media-cta-section__button {
    width: 100%;
    padding: 14px 16px;
  }
}
</style>

{% schema %}
{
  "name": "Media CTA Section",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media Type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image",
      "info": "Recommended: 1920×800px or wider."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image (optional)",
      "info": "If not set, the desktop image is used on mobile."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL",
      "info": "Direct URL to an MP4 file. Autoplay, loop, muted."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (H2)",
      "default": "Built for Riders, by Riders"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description / Subtitle",
      "default": "Pre-orders dropping soon."
    },
    {
      "type": "header",
      "content": "Email Form"
    },
    {
      "type": "checkbox",
      "id": "show_email_form",
      "label": "Show email signup form",
      "default": true
    },
    {
      "type": "text",
      "id": "input_placeholder",
      "label": "Input placeholder text",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Notify Me"
    }
  ],
  "presets": [
    {
      "name": "Media CTA Section",
      "settings": {
        "heading": "Built for Riders, by Riders",
        "description": "Pre-orders dropping soon.",
        "show_email_form": true,
        "button_label": "Notify Me",
        "input_placeholder": "your@email.com"
      }
    }
  ]
}
{% endschema %}
