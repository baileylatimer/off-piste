{%- liquid
  assign box_count = section.blocks.size
-%}

<section class="tech-feature-section" id="tech-feature-{{ section.id }}">
  <div class="tech-feature-section__grid{% if section.settings.invert_columns %} tech-feature-section__grid--inverted{% endif %}">

    <!-- Left: Text Column -->
    <div class="tech-feature-section__text-column">
      <div class="tech-feature-section__text-inner">

        <!-- Top content group -->
        <div class="tech-feature-section__content-group">
          {% if section.settings.overline != blank %}
            <p class="tech-feature-section__overline">{{ section.settings.overline | escape }}</p>
          {% endif %}

          {% if section.settings.heading != blank %}
            <h2 class="tech-feature-section__heading">{{ section.settings.heading | escape }}</h2>
          {% endif %}

          {% if section.settings.description != blank %}
            <div class="tech-feature-section__description">
              {{ section.settings.description }}
            </div>
          {% endif %}
        </div>

        <!-- Feature boxes at bottom -->
        {% if box_count > 0 %}
          <div class="tech-feature-section__boxes tech-feature-section__boxes--{{ box_count }}">
            {% for block in section.blocks %}
              <div class="tech-feature-section__box" {{ block.shopify_attributes }}>
                <div class="tech-feature-section__box-icon">
                  {%- comment -%} Custom image upload takes priority over built-in icon {%- endcomment -%}
                  {% if block.settings.icon_image != blank %}
                    <img
                      src="{{ block.settings.icon_image | image_url: width: 48 }}"
                      alt="{{ block.settings.title | escape }}"
                      width="24"
                      height="24"
                      loading="lazy"
                    >
                  {% else %}
                    {%- case block.settings.icon_select -%}
                      {%- when 'arrow-left' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                      {%- when 'arrow-right' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                      {%- when 'arrow-up' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="19" x2="12" y2="5"/><polyline points="5 12 12 5 19 12"/></svg>
                      {%- when 'arrow-down' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
                      {%- when 'arrows-updown' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="3" x2="12" y2="21"/><polyline points="17 8 12 3 7 8"/><polyline points="17 16 12 21 7 16"/></svg>
                      {%- when 'circle-dot' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="1" fill="currentColor"/></svg>
                      {%- when 'double-tap' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
                      {%- when 'music' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                      {%- when 'volume' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/></svg>
                      {%- when 'bluetooth' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6.5 6.5 17.5 17.5 12 23 12 1 17.5 6.5 6.5 17.5"/></svg>
                      {%- when 'hand' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>
                      {%- when 'zap' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                      {%- when 'wifi' -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>
                      {%- else -%}
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="1" fill="currentColor"/></svg>
                    {%- endcase -%}
                  {% endif %}
                </div>
                <div class="tech-feature-section__box-content">
                  {% if block.settings.title != blank %}
                    <p class="tech-feature-section__box-title">{{ block.settings.title | escape }}</p>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <p class="tech-feature-section__box-description">{{ block.settings.description | escape }}</p>
                  {% endif %}
                </div>
              </div>
            {% endfor %}
          </div>
        {% endif %}

      </div>
    </div>

    <!-- Right: Media Column -->
    <div class="tech-feature-section__media-column">
      <div class="tech-feature-section__media-wrapper">
        {% if section.settings.media_type == 'video' and section.settings.video_url != blank %}
          <video
            class="tech-feature-section__video"
            autoplay
            muted
            loop
            playsinline
          >
            <source src="{{ section.settings.video_url }}" type="video/mp4">
          </video>
        {% elsif section.settings.media_type == 'image' and section.settings.image != blank %}
          <img
            class="tech-feature-section__image"
            src="{{ section.settings.image | image_url: width: 1200 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {% else %}
          <div class="tech-feature-section__media-placeholder">
            {{ 'image' | placeholder_svg_tag: 'tech-feature-section__placeholder-svg' }}
          </div>
        {% endif %}
      </div>
    </div>

  </div>
</section>

<style>
/* ============================================
   TECH FEATURE SECTION
   ============================================ */

.tech-feature-section {
  margin-top: 8px;
}

.tech-feature-section__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
  align-items: stretch;
}

/* ---- Inverted column order (desktop only) ---- */
@media screen and (min-width: 750px) {
  .tech-feature-section__grid--inverted .tech-feature-section__text-column {
    order: 2;
  }
  .tech-feature-section__grid--inverted .tech-feature-section__media-column {
    order: 1;
  }
}

/* ---- Left Column ---- */
.tech-feature-section__text-column {
  background-color: #CDD5DA;
  border-radius: 8px;
  padding: 2em;
  display: flex;
  flex-direction: column;
}

.tech-feature-section__text-inner {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 100%;
  min-height: 550px;
  gap: 2em;
}

/* ---- Overline ---- */
.tech-feature-section__overline {
  font-family: var(--font-body) !important;
  font-size: 0.75rem !important;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: #171717;
  margin: 0 0 0.5em 0;
  opacity: 0.7;
}

/* ---- Heading ---- */
.tech-feature-section__heading {
  font-family: var(--font-header) !important;
  font-weight: var(--font-weight-semibold) !important;
  text-transform: uppercase !important;
  color: #171717 !important;
  margin: 0 0 0.5em 0;
  line-height: 1 !important;
}

/* ---- Description ---- */
.tech-feature-section__description {
  font-family: var(--font-body) !important;
  color: #171717;
  line-height: 1.5;
  text-transform: uppercase;
  margin: 0;
}

.tech-feature-section__description p {
  margin: 0;
  font-size: inherit !important;
}

/* ---- Content group ---- */
.tech-feature-section__content-group {
  display: flex;
  flex-direction: column;
  gap: 0.75em;
}

/* ---- Feature Boxes ---- */
.tech-feature-section__boxes {
  display: grid;
  gap: 8px;
  margin-top: auto;
}

/* 1 box: single column */
.tech-feature-section__boxes--1 {
  grid-template-columns: 1fr;
}

/* 2 boxes: two columns, one row */
.tech-feature-section__boxes--2 {
  grid-template-columns: 1fr 1fr;
}

/* 3 or 4 boxes: two columns, two rows */
.tech-feature-section__boxes--3,
.tech-feature-section__boxes--4 {
  grid-template-columns: 1fr 1fr;
}

.tech-feature-section__box {
  background-color: rgba(255, 255, 255, 0.25);
  border: 1px solid rgba(23, 23, 23, 0.15);
  border-radius: 6px;
  padding: 0.875em 1em;
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 0.75em;
}

.tech-feature-section__box-icon {
  flex-shrink: 0;
  width: 24px;
  height: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2px;
  color: #171717;
}

.tech-feature-section__box-icon img {
  width: 24px;
  height: 24px;
  object-fit: contain;
  display: block;
}

.tech-feature-section__box-icon-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
}

.tech-feature-section__box-content {
  display: flex;
  flex-direction: column;
  gap: 0.2em;
}

.tech-feature-section__box-title {
  font-family: var(--font-header) !important;
  font-weight: var(--font-weight-semibold) !important;
  font-size: 0.8rem !important;
  text-transform: uppercase !important;
  color: #171717;
  margin: 0 !important;
  line-height: 1.2 !important;
  letter-spacing: 0.03em;
}

.tech-feature-section__box-description {
  font-family: var(--font-body) !important;
  font-size: 0.7rem !important;
  text-transform: uppercase;
  color: #171717;
  opacity: 0.65;
  margin: 0 !important;
  line-height: 1.3 !important;
}

/* ---- Right Column (Media) ---- */
.tech-feature-section__media-column {
  border-radius: 8px;
  overflow: hidden;
  position: relative;
  min-height: 400px;
}

.tech-feature-section__media-wrapper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.tech-feature-section__video,
.tech-feature-section__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.tech-feature-section__media-placeholder {
  width: 100%;
  height: 100%;
  background-color: #b0bec5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tech-feature-section__placeholder-svg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ============================================
   RESPONSIVE — TABLET
   ============================================ */
@media screen and (min-width: 750px) and (max-width: 1023px) {
  .tech-feature-section__text-inner {
    min-height: 480px;
  }

  .tech-feature-section__text-column {
    padding: 1.5em;
  }
}

/* ============================================
   RESPONSIVE — MOBILE
   ============================================ */
@media screen and (max-width: 749px) {
  .tech-feature-section {
    margin-top: 8px;
  }

  .tech-feature-section__grid {
    grid-template-columns: 1fr;
    gap: 8px;
  }

  /* Media on top, text below */
  .tech-feature-section__media-column {
    order: 1;
    min-height: 280px;
    position: relative;
  }

  .tech-feature-section__media-wrapper {
    position: relative;
    width: 100%;
    height: 280px;
  }

  .tech-feature-section__text-column {
    order: 2;
    padding: 1.25em 1.25em 1.5em;
  }

  .tech-feature-section__text-inner {
    min-height: unset;
    gap: 1.5em;
  }

  /* On mobile, boxes always stack 2-col if 3-4, or 1-col if 1-2 */
  .tech-feature-section__boxes--1 {
    grid-template-columns: 1fr;
  }

  .tech-feature-section__boxes--2 {
    grid-template-columns: 1fr 1fr;
  }

  .tech-feature-section__boxes--3,
  .tech-feature-section__boxes--4 {
    grid-template-columns: 1fr 1fr;
  }

  .tech-feature-section__box {
    padding: 0.75em 0.75em;
    gap: 0.5em;
  }

  .tech-feature-section__box-title {
    font-size: 0.7rem !important;
  }

  .tech-feature-section__box-description {
    font-size: 0.65rem !important;
  }
}
</style>

{% schema %}
{
  "name": "Tech Feature Section",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Overline",
      "default": "001 / MUSIC CONTROLS",
      "info": "Small label above the heading (e.g. '001 / MUSIC CONTROLS')"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (H1)",
      "default": "Your Ride. Your Soundtrack. Zero Interruptions."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Gesture recognition built into the glove lets you skip tracks, adjust volume, and pause your music with simple hand movements — without breaking your flow.</p>"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media Type",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Recommended: 800×1000px or taller. Used when Media Type is set to Image."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL",
      "info": "Direct URL to an MP4 file. Video will autoplay, loop, and be muted. Used when Media Type is set to Video."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "invert_columns",
      "label": "Invert column order",
      "default": false,
      "info": "When enabled, the media appears on the left and the text on the right (desktop only)."
    }
  ],
  "blocks": [
    {
      "type": "feature_box",
      "name": "Feature Box",
      "settings": [
        {
          "type": "header",
          "content": "Icon"
        },
        {
          "type": "select",
          "id": "icon_select",
          "label": "Built-in Icon",
          "default": "circle-dot",
          "info": "Choose a built-in icon. Upload a custom image below to override.",
          "options": [
            { "value": "arrow-left",   "label": "← Arrow Left" },
            { "value": "arrow-right",  "label": "→ Arrow Right" },
            { "value": "arrow-up",     "label": "↑ Arrow Up" },
            { "value": "arrow-down",   "label": "↓ Arrow Down" },
            { "value": "arrows-updown","label": "↕ Arrows Up/Down" },
            { "value": "circle-dot",   "label": "⊙ Circle Dot" },
            { "value": "double-tap",   "label": "◎ Double Tap" },
            { "value": "music",        "label": "♪ Music Note" },
            { "value": "volume",       "label": "🔊 Volume" },
            { "value": "bluetooth",    "label": "Bluetooth" },
            { "value": "hand",         "label": "✋ Hand / Gesture" },
            { "value": "zap",          "label": "⚡ Zap" },
            { "value": "wifi",         "label": "Wifi" }
          ]
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom Icon Image (optional)",
          "info": "Upload a PNG or SVG (~48×48px). If set, this overrides the built-in icon above."
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Swipe Left"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Prev Track"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tech Feature Section",
      "blocks": [
        {
          "type": "feature_box",
          "settings": {
            "icon_select": "arrow-left",
            "title": "Swipe Left",
            "description": "Prev Track"
          }
        },
        {
          "type": "feature_box",
          "settings": {
            "icon_select": "arrow-right",
            "title": "Swipe Right",
            "description": "Next Track"
          }
        },
        {
          "type": "feature_box",
          "settings": {
            "icon_select": "arrows-updown",
            "title": "Swipe Up/Down",
            "description": "Volume Control"
          }
        },
        {
          "type": "feature_box",
          "settings": {
            "icon_select": "double-tap",
            "title": "Double Tap",
            "description": "Play / Pause"
          }
        }
      ]
    }
  ]
}
{% endschema %}
